# =============================================================================
# Render Production Environment Variables
# =============================================================================
# Copy the values below into:
#   Render Dashboard → Your Service → Environment → Add Environment Variable
#
# Variables marked "auto" are generated/injected by Render automatically.
# Variables marked "generateValue: true" in render.yaml are auto-generated.
# =============================================================================


# ── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
# PORT is injected automatically by Render — do NOT set this manually


# ── Database (Supabase) ──────────────────────────────────────────────────────
# From: Supabase Dashboard → Project Settings → Database → Connection string
# Use the "Transaction pooler" URL (port 6543) for serverless/auto-scaling.
# Format: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres


# ── Auth (generate with: openssl rand -hex 32) ──────────────────────────────
JWT_SECRET=replace_with_64_char_random_hex
JWT_REFRESH_SECRET=replace_with_a_different_64_char_random_hex
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d


# ── CORS ─────────────────────────────────────────────────────────────────────
# Your Vercel frontend URL (no trailing slash)
CORS_ORIGIN=https://your-app.vercel.app


# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CURRENCY=usd
STRIPE_SUCCESS_URL=https://your-app.vercel.app/booking/success
STRIPE_CANCEL_URL=https://your-app.vercel.app/booking/cancel


# ── Email (Nodemailer / SMTP) ─────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your@gmail.com
# Use a Gmail App Password: https://myaccount.google.com/apppasswords
SMTP_PASS=xxxx_xxxx_xxxx_xxxx
EMAIL_FROM=noreply@yourdomain.com


# ── Twilio SMS (optional — leave blank to disable) ────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=


# ── Google OAuth (required for Google login) ──────────────────────────────────
# Create credentials: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Google Calendar (optional — leave blank to disable) ───────────────────────
# Must match the OAuth redirect registered in Google Cloud Console
GOOGLE_REDIRECT_URI=https://booking-system-3rzn.onrender.com/api/calendar/oauth/callback
GOOGLE_CALENDAR_ID=primary
# 32-byte hex key: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=
