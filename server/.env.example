# ============================================================
# BookFlow Server — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Generate secrets with:  openssl rand -hex 32
# ============================================================

# ════════════════════════════════════════════════════════════
#  Server
# ════════════════════════════════════════════════════════════
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
CLIENT_URL=http://localhost:3000

# ════════════════════════════════════════════════════════════
#  Logging
#  LOG_LEVEL: error | warn | info | http | debug
#  Leave unset to use the env-based default (info in prod, debug in dev)
# ════════════════════════════════════════════════════════════
LOG_LEVEL=debug

# ════════════════════════════════════════════════════════════
#  PostgreSQL
# ════════════════════════════════════════════════════════════
# Option A: Connection string (Supabase / Render / Neon)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Option B: Individual vars (local development)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bookingdb
DB_USER=postgres
DB_PASSWORD=your_db_password

# ════════════════════════════════════════════════════════════
#  JWT  (must be >= 32 characters each in production)
# ════════════════════════════════════════════════════════════
JWT_SECRET=replace_with_a_random_32_plus_char_secret_here
JWT_REFRESH_SECRET=replace_with_a_different_random_32_plus_char_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ════════════════════════════════════════════════════════════
#  Email (Gmail SMTP)
#  Create an App Password: https://myaccount.google.com/apppasswords
# ════════════════════════════════════════════════════════════
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM=BookFlow <your_email@gmail.com>

# ════════════════════════════════════════════════════════════
#  Google OAuth (required for Google login)
#  Create credentials: https://console.cloud.google.com/apis/credentials
# ════════════════════════════════════════════════════════════
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ════════════════════════════════════════════════════════════
#  Google Calendar (optional)
# ════════════════════════════════════════════════════════════
GOOGLE_REDIRECT_URI=http://localhost:5000/api/calendar/oauth/callback
GOOGLE_CALENDAR_ID=primary
TOKEN_ENCRYPTION_KEY=32_byte_hex_encryption_key

# ════════════════════════════════════════════════════════════
#  Twilio SMS (optional — SMS features disabled without it)
# ════════════════════════════════════════════════════════════
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# ════════════════════════════════════════════════════════════
#  Stripe (optional — demo payments work without it)
# ════════════════════════════════════════════════════════════
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CURRENCY=usd
STRIPE_SUCCESS_URL=http://localhost:3000/booking/success
STRIPE_CANCEL_URL=http://localhost:3000/booking/cancel

# ════════════════════════════════════════════════════════════
#  Frontend (used by server for building email links)
# ════════════════════════════════════════════════════════════
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
NEXT_PUBLIC_TWILIO_PHONE_NUMBER=+1234567890
