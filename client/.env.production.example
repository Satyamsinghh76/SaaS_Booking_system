# =============================================================================
# Vercel Production Environment Variables
# =============================================================================
# Set these in:
#   Vercel Dashboard → Project → Settings → Environment Variables
#   Select "Production" (and optionally "Preview") for each.
#
# NEXT_PUBLIC_* variables are embedded into the client bundle at build time.
# They are safe to expose to the browser — do NOT put secrets here.
# =============================================================================


# ── Backend API (your Render service URL) ────────────────────────────────────
# Find this in: Render Dashboard → Your Service → URL
# No trailing slash.
NEXT_PUBLIC_API_URL=https://saas-booking-api.onrender.com
